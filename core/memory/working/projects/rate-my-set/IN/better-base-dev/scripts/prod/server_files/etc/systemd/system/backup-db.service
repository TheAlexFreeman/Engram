[Unit]
Description=Daily Database and Fixtures Backup
After=network.target postgresql.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/proj/better-base

# Add timeout of 22 hours (79200 seconds).
TimeoutSec=79200

# Set environment variables for AWS
Environment=AWS_CONFIG_FILE=/home/ubuntu/.aws/config
Environment=AWS_SHARED_CREDENTIALS_FILE=/home/ubuntu/.aws/credentials
# Force Python output to be flushed immediately.
Environment=PYTHONUNBUFFERED=1

# Set up error handling and strict mode.
ExecStart=/bin/bash -c 'set -euo pipefail; \
    chmod 700 /home/ubuntu/proj/better-base/scripts/prod/server_files/proj/better-base/backup_db_and_fixtures.py && \
    /usr/bin/python3 /home/ubuntu/proj/better-base/scripts/prod/server_files/proj/better-base/backup_db_and_fixtures.py'

# Logging - Write output to the journal.
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
