{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "plugins": ["react", "typescript"],
  "rules": {
    "no-console": "warn",
    "react/react-in-jsx-scope": "off",
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/no-floating-promises": "error",
    "typescript/no-base-to-string": "off"
  },
  "ignorePatterns": [
    ".cache",
    ".coverage",
    ".mypy_cache",
    ".pytest_cache",
    ".react-email",
    ".ruff_cache",
    ".swc",
    ".venv",
    ".vscode",
    "__pycache__",
    "AGENTS.md",
    "backend",
    "build",
    "chakra-ejected-example",
    "CLAUDE.md",
    "dist",
    "dist-ssr",
    "docs",
    "emails/exported",
    "htmlcov",
    "node_modules",
    "openapi/generated",
    "public",
    "routeTree.gen.ts",
    "staticfiles"
  ]
}
