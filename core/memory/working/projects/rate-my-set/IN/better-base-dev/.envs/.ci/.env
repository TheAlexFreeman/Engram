# NOTE: `.envs/.ci/.env` (this file) is committed to version control so be careful to
# not put sensitive secrets/data in here, etc. All of these values, in practice, should
# be non-secret values for tests, etc., and anything that would be sensitive in dev
# probably wouldn't need to be sensitive here (it it is can inject with GitHub secrets,
# etc.).

# General
# ==============================================================================
ENVIRONMENT=ci

# Django
# ==============================================================================
DJANGO_DEBUG=True
DJANGO_LOG_LEVEL=INFO

# URL/Site Info
# ------------------------------------------------------------------------------
DEFAULT_SITE_DOMAIN=localhost:8000
DEFAULT_SITE_NAME=Better Base
BASE_BACKEND_URL=http://localhost:8000/base-backend-url
BASE_WEB_APP_URL=http://localhost:8000/base-web-app-url
BASE_LANDING_SITE_URL=http://localhost:8000/base-landing-site-url

# CI Secrets
# ==============================================================================
DJANGO_SECRET_KEY=x~~~xREPLACEx~~~x--DJANGO_SECRET_KEY_CI

# CI Specific
# ==============================================================================

# Django Cachalot
# ------------------------------------------------------------------------------
CACHALOT_ENABLED=False
