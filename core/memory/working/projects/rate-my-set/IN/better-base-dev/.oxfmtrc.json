{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "experimentalSortImports": {
    "customGroups": [
      {
        "elementNamePattern": ["vite"],
        "groupName": "vite-group"
      },
      {
        "elementNamePattern": ["react", "react-dom"],
        "groupName": "react-group"
      }
    ],
    "groups": [
      "type-import",
      "vite-group",
      "react-group",
      ["value-builtin", "value-external"],
      "type-internal",
      "value-internal",
      ["type-parent", "type-sibling", "type-index"],
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ],
    "ignoreCase": true,
    "internalPattern": ["@/", "~/"],
    "newlinesBetween": true,
    "order": "asc"
  },
  "ignorePatterns": [
    "*.toml",
    ".cache",
    ".coverage",
    ".dmypy.json",
    ".git",
    ".gitignore",
    ".mypy_cache",
    ".pytest_cache",
    ".react-email",
    ".ruff_cache",
    ".swc",
    ".venv",
    ".vscode",
    "__pycache__",
    "__pycache__/*",
    "backend/static/js/jsoneditor",
    "backend/templates",
    "backend/templates/*",
    "build",
    "chakra-ejected-example",
    "emails/exported/html",
    "emails/exported/html/*",
    "emails/exported/txt",
    "emails/exported/txt/*",
    "dist",
    "dist-ssr",
    "docs",
    "htmlcov",
    "node_modules",
    "node_modules/*",
    "openapi/generated/*",
    "package-lock.json",
    "public",
    "public/*",
    "routeTree.gen.ts",
    "staticfiles",
    "staticfiles/*"
  ],
  "overrides": [
    {
      "files": ["*.yaml", "*.yml"],
      "options": {
        "singleQuote": false
      }
    }
  ],
  "printWidth": 100,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false
}
